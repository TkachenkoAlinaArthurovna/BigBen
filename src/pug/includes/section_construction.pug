                    .section_construction__subbutton(id="line_2") 2 Черга
                    .section_construction__subbutton(id="line_test") test Черга
        .section_construction__display
            .display(data-house="house_2" data-line="line_2")
                .display__top 
                    .display__date_update Дата оновлення 
                        span (12.03.2025)
                    .display__date_end Дата планового завершення будівництва 
                        span (20.05.2027)
                .display__ranges 
                    .display__ranges_title(id="status")
